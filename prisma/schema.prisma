generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String  @id
  name        String
  email       String  @unique
  role        String
  avatarUrl   String?
  passwordHash String?
  githubToken String?

  patches       NotePatch[] @relation("PatchAuthor")
  hotfixes      Hotfix[]    @relation("HotfixReporter")
  documents     Document[]
  auditLogs     AuditLog[]
  projectsCreated Project[] @relation("ProjectCreatedBy")
  projectsProcesso Project[] @relation("ProjectProcesso")
  projectsDev    Project[] @relation("ProjectDev")
  projectsQA     Project[] @relation("ProjectQA")
}

model Classification {
  id          String  @id
  name        String
  color       String
  description String
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  parentId    String?
  versionPrefix String?

  patches     NotePatch[]
  children    Classification[] @relation("ClassificationHierarchy")
  parent      Classification?  @relation("ClassificationHierarchy", fields: [parentId], references: [id])
}

model NotePatch {
  id               String   @id
  version          String
  title            String
  summary          String
  technicalNotes   String
  status           String
  tags             String   // JSON array
  authorId         String
  reviewerId       String?
  githubRepo       String?
  githubBranch     String?
  githubCommitSha  String?
  githubPrUrl      String?
  githubFiles      String   // JSON array
  affectedClasses  String   // JSON array
  impactedSystems  String   // JSON array
  rollbackPlan     String?
  checklist        String   // JSON array
  codeReferences   String?  // JSON array of {repo, path, sha, lines, content}
  deployedAt       DateTime
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isHotfix         Boolean  @default(false)
  favorite         Boolean  @default(false)
  classificationId String

  author         User           @relation("PatchAuthor", fields: [authorId], references: [id])
  classification Classification @relation(fields: [classificationId], references: [id])
  hotfixes       Hotfix[]
  documents      Document[]
}

model Hotfix {
  id                    String    @id
  title                 String
  severity              String
  affectedSystem        String
  description           String
  commitSha             String?
  status                String
  reportedById          String
  reportedAt            DateTime
  deployedAt            DateTime?
  resolvedAt            DateTime?
  resolvedBy            String?
  resolutionTimeMinutes Int?
  postMortemNeeded      Boolean   @default(false)
  postMortemDone        Boolean   @default(false)
  codeReferences        String?   // JSON array of {repo, path, sha, lines, content}
  patchId               String?

  reporter User       @relation("HotfixReporter", fields: [reportedById], references: [id])
  patch    NotePatch? @relation(fields: [patchId], references: [id])
}

model Document {
  id               String   @id
  title            String
  type             String
  fileUrl          String
  fileSize         Int
  tags             String   // JSON array
  visibility       String
  versions         String   // JSON array
  patchId          String?
  projectId        String?
  classificationId String?
  uploadedById     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  uploadedBy User       @relation(fields: [uploadedById], references: [id])
  patch      NotePatch? @relation(fields: [patchId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  entity    String
  entityId  String
  details   String   // JSON object
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  userName    String
  entityType  String   // 'patch' | 'hotfix' | 'project'
  entityId    String   // patchId, hotfixId, or classificationId
  hours       Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  title         String
  type          String   // 'hotfix_emergencial' | 'patch_note'
  description   String
  status        String   // 'draft' | 'em_processo' | 'desenvolvimento' | 'qa' | 'hotfix' | 'publicado' | 'concluido'
  currentStage  String?  // 'processo' | 'dev' | 'qa' | 'hotfix' | null
  targetDate    DateTime
  createdById   String
  createdByName String
  processoId    String?
  devId         String?
  qaId          String?
  isPublic      Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stages        ProjectStage[]
  documents     Document[]

  createdBy     User     @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  processo      User?    @relation("ProjectProcesso", fields: [processoId], references: [id])
  dev           User?    @relation("ProjectDev", fields: [devId], references: [id])
  qa            User?    @relation("ProjectQA", fields: [qaId], references: [id])
}

model ProjectStage {
  id          String   @id @default(cuid())
  projectId   String
  stage       String   // 'processo' | 'desenvolvimento' | 'qa' | 'hotfix' | 'publicado'
  userId      String
  userName    String
  description String
  publishedAt DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}
